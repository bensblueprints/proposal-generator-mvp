# Pitchcraft configuration — copy to .env and edit

# Port the web app listens on
PORT=5348

# Admin password for the proposal builder (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/pitchcraft.db

# Public base URL of this install — shown in copied client links
# e.g. https://proposals.yourdomain.com
BASE_URL=

# Where "proposal opened/accepted/commented" notifications go (optional)
NOTIFY_EMAIL=

# SMTP for those notifications (optional — the app works fine without email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
